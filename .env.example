# Samaritan Web UI — environment config
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.

# Token required from the browser to access this app.
# Set this to any strong secret string. The browser will prompt for it once.
SAMARITAN_API_KEY=change-me-to-a-strong-secret

# Token forwarded to agent-mcp (must match API_KEY in agent-mcp's .env).
# Leave blank if agent-mcp has no API_KEY set.
AGENT_MCP_API_KEY=

# agent-mcp base URL (default: local)
AGENT_MCP_URL=http://localhost:8767

# xAI API key — used server-side only to mint ephemeral tokens for the
# Realtime voice WebSocket (POST /api/voice-token). Never sent to browser.
# Required for voice responses (FULL VOICE mode).
# Get one at https://console.x.ai/
XAI_API_KEY=
